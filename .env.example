# B0-01 baseline — no production secrets required.
# Real secret schemas are added per process entrypoint in later tasks (api.env.ts / worker.env.ts).
NODE_ENV=development
LOG_LEVEL=info

# API process (per BACKEND-ARCHITECTURE.md > Configuration boundaries)
API_PORT=4000
API_HOST=127.0.0.1

# Worker process
WORKER_NAME=lembar-worker
