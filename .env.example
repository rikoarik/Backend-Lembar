# B0-02 baseline — typed per-process env schemas (api.env.ts, worker.env.ts).
# Safe defaults exist for local install / typecheck / unit tests.
# No production secrets are required here.

# Shared base (parsed by src/config/base.env.ts)
NODE_ENV=development           # development | test | production
APP_ENV=local                  # local | test | preview | staging | production
SERVICE_NAME=lembar-backend
SERVICE_VERSION=0.0.0-dev
LOG_LEVEL=info                 # fatal | error | warn | info | debug | trace | silent

# API process (parsed by src/config/api.env.ts)
API_PORT=4000                  # integer 1..65535
API_HOST=127.0.0.1
CORS_ALLOWED_ORIGINS=          # comma-separated origins; wildcard "*" rejected
PUBLIC_APP_URL=http://localhost:3000   # required when APP_ENV=production

# Worker process (parsed by src/config/worker.env.ts)
WORKER_NAME=lembar-worker
WORKER_CONCURRENCY=1           # integer 1..64

# Secrets (DB keys, auth signing, AI/storage/payment keys, webhook secrets)
# are NOT configured here. They are added per-process by later tasks once
# provider/feature decisions are accepted, and must never be committed.
